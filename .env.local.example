# ============================================================
# SOUVENIRS DE ROUTE — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez les valeurs
# ============================================================

# --- OBLIGATOIRE ---

# Clé API Unsplash (photos destinations et articles)
# Créez un compte sur https://unsplash.com/developers
# IMPORTANT : ajouter également cette variable dans Vercel Dashboard
UNSPLASH_ACCESS_KEY=votre_cle_unsplash_ici

# URL de base du site (sitemap, meta OG)
NEXT_PUBLIC_SITE_URL=https://souvenirsderoute.com

# --- ANALYTICS ---

# Google Analytics 4 (Measurement ID, format G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Plausible (alternative RGPD à GA, domaine sans https://)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=souvenirsderoute.com

# --- NEWSLETTER ---

# Brevo (anciennement Sendinblue) — clé API v3
BREVO_API_KEY=xkeysib-votre_cle_brevo

# --- COMMENTAIRES ---

# Giscus (commentaires via GitHub Discussions)
# Configurez sur https://giscus.app/fr
NEXT_PUBLIC_GISCUS_REPO=username/nom-du-repo
NEXT_PUBLIC_GISCUS_REPO_ID=R_kgDO...
NEXT_PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDO...

# --- DÉVELOPPEMENT ---

# Mode développement (optionnel)
NODE_ENV=development
