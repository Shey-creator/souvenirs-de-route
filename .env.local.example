# Clé API Unsplash (obligatoire pour les photos)
# Créez un compte sur https://unsplash.com/developers
# Puis créez une application pour obtenir votre clé
UNSPLASH_ACCESS_KEY=votre_cle_unsplash_ici

# URL de base du site (utilisée pour le sitemap et les meta OG)
NEXT_PUBLIC_SITE_URL=https://souvenirsderoute.com

# Analytics Plausible (optionnel)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=souvenirsderoute.com

# Mode de développement (optionnel)
NODE_ENV=development
